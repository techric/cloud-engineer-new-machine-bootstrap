# =============================================================================
# .gitignore — Cloud Engineer Toolchain
# =============================================================================
# This file tells Git which files and folders to ignore — meaning they will
# never be committed to the repo even if they exist on your local machine.
#
# WHY THIS MATTERS:
#   Some files are auto-generated by your OS or tools and have no business
#   being in version control. Committing them adds noise, can expose sensitive
#   data, and creates unnecessary conflicts between engineers on different
#   operating systems.
# =============================================================================

# =============================================================================
# macOS SYSTEM FILES
# macOS automatically creates these files in every folder you open in Finder.
# They store display preferences (icon positions, window sizes) and are
# completely irrelevant to anyone else working with this repo.
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# =============================================================================
# SECRETS & CREDENTIALS
# These file patterns commonly contain sensitive data — API keys, passwords,
# certificates, and tokens. They must NEVER be committed to any repo.
# If you accidentally create one of these files locally, Git will ignore it.
# =============================================================================
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*credentials*
*secret*
*token*
*.kubeconfig

# =============================================================================
# CLOUD PROVIDER FILES
# Authentication files created by cloud CLIs when you log in.
# These contain your personal credentials and must never be committed.
# =============================================================================
.aws/
.gcp/
gcloud/
service-account*.json
*-service-account.json
application_default_credentials.json

# =============================================================================
# TERRAFORM
# Terraform creates local state files and lock files that contain
# sensitive infrastructure details and should not be committed.
# =============================================================================
*.tfstate
*.tfstate.*
*.tfvars
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json

# =============================================================================
# EDITOR & IDE FILES
# Auto-generated files created by code editors and IDEs.
# These are personal preferences and not part of the project.
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# LOGS & TEMPORARY FILES
# Log files and temp files generated during script execution.
# =============================================================================
*.log
tmp/
temp/
EOF
echo "Done"